<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeRacer.Client.ViewModels"
             xmlns:models="using:TypeRacer.Client.Models"
             x:Class="TypeRacer.Client.Views.RaceView"
             x:DataType="vm:RaceViewModel">

    <UserControl.Styles>
        <Style Selector="ProgressBar">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#725AC1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Value" Duration="0:0:0.4" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid Background="#0B0A10">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="800" Height="800" Fill="#0D725AC1" Margin="-300,-400,0,0">
                <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <StackPanel MaxWidth="1000" 
                    Margin="60" 
                    Spacing="60" 
                    VerticalAlignment="Center">
            
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="TYPE SPEED ARENA" 
                               Foreground="#725AC1" 
                               FontSize="14" 
                               FontWeight="Black" 
                               LetterSpacing="5"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="#4A4860" 
                               FontSize="16"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                    <StackPanel HorizontalAlignment="Right">
                        <TextBlock Text="{Binding WpmText}" 
                                   Foreground="White" 
                                   FontSize="32" 
                                   FontWeight="Light"/>
                        <TextBlock Text="WORDS PER MINUTE" 
                                   Foreground="#4A4860" 
                                   FontSize="10" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid>
                <ItemsControl ItemsSource="{Binding DisplayCharacters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:RaceCharacterInfo">
                            <Border Background="{Binding BackgroundColor}" 
                                    CornerRadius="2"
                                    Margin="0,4"> 
                                <TextBlock Text="{Binding Character}" 
                                           FontSize="34" 
                                           FontFamily="Consolas, Monospace" 
                                           Foreground="{Binding ForegroundColor}"
                                           Padding="1,0"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <TextBox x:Name="HiddenInputBox"
                         Text="{Binding TypedText}"
                         Opacity="0" Width="0" Height="0"/>
            </Grid>

            <StackPanel Spacing="24">
                <Border BorderBrush="#1AFFFFFF" BorderThickness="0,1,0,0" Padding="0,24,0,0">
                    <TextBlock Text="LEADERBOARD" 
                               Foreground="#333145" 
                               FontSize="11" 
                               FontWeight="Bold" 
                               LetterSpacing="3"/>
                </Border>

                <ItemsControl ItemsSource="{Binding Opponents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:OpponentProgressInfo">
                            <Grid ColumnDefinitions="150, *, 100" Margin="0,0,0,20">
                                <TextBlock Grid.Column="0" 
                                           Text="{Binding Name}" 
                                           Foreground="#8E8C9E" 
                                           FontSize="15" 
                                           VerticalAlignment="Center"/>
                                
                                <ProgressBar Grid.Column="1" 
                                             Value="{Binding ProgressPercent}" 
                                             VerticalAlignment="Center"
                                             Margin="20,0"/>

                                <TextBlock Grid.Column="2" 
                                           Text="{Binding WpmText}" 
                                           Foreground="#725AC1" 
                                           FontSize="14" 
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>