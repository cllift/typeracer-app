<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeRacer.Client.ViewModels"
             x:Class="TypeRacer.Client.Views.ResultsView"
             x:DataType="vm:ResultsViewModel">

    <Grid Background="#0B0A10">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="700" Height="700" Fill="#0D725AC1" Margin="-200,-300,0,0">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <StackPanel MaxWidth="900" 
                    Margin="60" 
                    Spacing="50" 
                    VerticalAlignment="Center">

            <StackPanel Spacing="12">
                <TextBlock Text="RACE COMPLETE" 
                           Foreground="#725AC1" 
                           FontSize="14" 
                           FontWeight="Black" 
                           LetterSpacing="6"
                           HorizontalAlignment="Center"/>
                
                <TextBlock Text="{Binding WinnerText}" 
                           Foreground="White" 
                           FontSize="48" 
                           FontWeight="Light" 
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Spacing="20">
                <Grid ColumnDefinitions="80, *, 120, 150" Margin="20,0">
                    <TextBlock Text="RANK" Foreground="#333145" FontSize="11" FontWeight="Bold" LetterSpacing="2"/>
                    <TextBlock Grid.Column="1" Text="PLAYER" Foreground="#333145" FontSize="11" FontWeight="Bold" LetterSpacing="2"/>
                    <TextBlock Grid.Column="2" Text="SPEED" Foreground="#333145" FontSize="11" FontWeight="Bold" LetterSpacing="2" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="STATUS" Foreground="#333145" FontSize="11" FontWeight="Bold" LetterSpacing="2" HorizontalAlignment="Right"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="20" 
                                    Margin="0,4" 
                                    Background="#12111A" 
                                    CornerRadius="12"
                                    BorderBrush="#1AFFFFFF"
                                    BorderThickness="1">
                                <Grid ColumnDefinitions="80, *, 120, 150">
                                    <TextBlock Text="{Binding PositionText}" 
                                               Foreground="#725AC1" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding PlayerName}" 
                                               Foreground="White" 
                                               FontSize="18" 
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding WpmText}" 
                                                   Foreground="White" 
                                                   FontSize="20" 
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="3" 
                                               Text="{Binding StatusText}" 
                                               Foreground="#8E8C9E" 
                                               FontSize="13" 
                                               HorizontalAlignment="Right" 
                                               VerticalAlignment="Center"
                                               FontWeight="Medium"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" Spacing="20">
                <Button Command="{Binding PlayAgainCommand}"
                        Classes="Primary"
                        Width="240"
                        Height="54"
                        Background="#725AC1"
                        Foreground="White"
                        CornerRadius="12"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="NEXT RACE" FontWeight="Bold" LetterSpacing="2"/>
                    </StackPanel>
                    
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#8A72D9"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>